  "title": "Red Hat Security Advisory: OpenShift Container Platform 4.13.60 bug fix and security update",
  "issuedDate": "2025-09-18T04:52:06+00:00",
  "updatedDate": "2025-09-18T04:52:13+00:00",
  "pubDate": "2025-09-18T04:52:06+00:00",
