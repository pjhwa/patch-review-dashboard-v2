{
  "id": "RHSA-2026:2769",
  "vendor": "Red Hat",
  "type": "Security Advisory (RHSA)",
  "title": "Red Hat Security Advisory: Red Hat Ceph Storage 7.1 security and bug fix updates",
  "issuedDate": "2026-02-17T00:55:59+00:00",
  "updatedDate": "2026-02-17T00:55:59+00:00",
  "pubDate": "2026-02-17T00:55:59+00:00",
