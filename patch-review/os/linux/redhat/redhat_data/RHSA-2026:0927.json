  "type": "Security Advisory (RHSA)",
  "title": "Red Hat Security Advisory: java-17-openjdk security update",
  "issuedDate": "2026-01-22T09:24:37+00:00",
  "updatedDate": "2026-01-22T09:24:37+00:00",
