# Patch Review Dashboard V2 — Environment Variables

# SQLite Database (Prisma)
# Path is relative to the project root
DATABASE_URL="file:./prisma/patch-review.db"

# Redis connection for BullMQ job queue
# Must be running before the application starts
REDIS_URL="redis://127.0.0.1:6379"

# Redis with authentication (if required)
# REDIS_URL="redis://:yourpassword@127.0.0.1:6379"
