# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
*.bak

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Database files
*.db
*.db-*

# Logs
server.log

# Pipeline ignores
**/node_modules
**/__pycache__
**/archive
!src/app/api/archive
!src/app/category/*/archive
**/venv

# Patch Data (Prevent massive JSON pushes, allow only samples)
*_data/*
!*_data/*.sample.json
ubuntu-security-notices/

# Pipeline runtime output files (generated by pipeline, not source)
patches_for_llm_review*.json
patch_review_ai_report_*.json
dropped_patches_audit_*.csv
final_approved_patches_*.csv
debug_prompt_*.txt
cron_*.log
cookie.txt
